{
  "name": "nexus-collector",
  "version": "1.0.0",
  "description": "NEXUS Infiltration - Data Collection Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test.js",
    "data:init": "mkdir -p data/submissions && echo '{\"totalSubmissions\":0,\"uniqueHosts\":[],\"submissions\":[],\"createdAt\":\"'$(date -Iseconds)'\",\"lastUpdated\":\"'$(date -Iseconds)'\"}' > data/stats.json",
    "data:clean": "rm -rf data/submissions/*.json && echo '{\"totalSubmissions\":0,\"uniqueHosts\":[],\"submissions\":[],\"createdAt\":\"'$(date -Iseconds)'\",\"lastUpdated\":\"'$(date -Iseconds)'\"}' > data/stats.json",
    "data:backup": "tar -czf data-backup-$(date +%Y%m%d-%H%M%S).tar.gz data/"
  },
  "keywords": [
    "hackathon",
    "system-info",
    "data-collection"
  ],
  "author": "Team Nexus",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "express-rate-limit": "^6.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}