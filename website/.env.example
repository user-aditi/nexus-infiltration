# ============================================
# NEXUS COLLECTOR - ENVIRONMENT VARIABLES
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=production

# Security - CHANGE THESE VALUES
NEXUS_SECRET=your-super-secret-key-change-this
ADMIN_PASSWORD=your-admin-password-change-this

# Data Storage Path
DATA_DIR=./data

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=50mb

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info